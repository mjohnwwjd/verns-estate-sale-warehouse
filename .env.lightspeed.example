# Copy this file to .env.lightspeed.local after registering the API client.
# Do not commit .env.lightspeed.local.

LIGHTSPEED_CLIENT_ID=
LIGHTSPEED_CLIENT_SECRET=
LIGHTSPEED_REDIRECT_URI=https://estatesbyvern.com/lightspeed/callback

# Start narrow. If categories/photos need another scope, add it after testing.
LIGHTSPEED_SCOPE=employee:inventory_read

# R-Series OAuth/API defaults. Override only if Lightspeed changes the endpoint shown in their docs.
LIGHTSPEED_AUTH_URL=https://cloud.lightspeedapp.com/auth/oauth/authorize
LIGHTSPEED_TOKEN_URL=https://cloud.lightspeedapp.com/auth/oauth/token
LIGHTSPEED_API_BASE=https://api.lightspeedapp.com/API/V3

# R-Series uses the redirect URI registered with the API client.
# Set true only if Lightspeed support specifically asks for it.
LIGHTSPEED_AUTH_INCLUDE_REDIRECT_URI=false
LIGHTSPEED_TOKEN_INCLUDE_REDIRECT_URI=false

# Filled in after token exchange by scripts/lightspeed-exchange-code.mjs.
LIGHTSPEED_ACCOUNT_ID=
